# API Configuration
# Update these values based on your environment

# Production API URL
EXPO_PUBLIC_API_URL=https://bookmovieticket-eelf.onrender.com/api

# For development with local backend
# EXPO_PUBLIC_API_URL=http://localhost:5001/api

# For emulator/physical device testing (replace with your computer's IP address)
# Find your IP using: ipconfig (Windows) or ifconfig (Mac/Linux)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5001/api

# Node Environment
NODE_ENV=production
